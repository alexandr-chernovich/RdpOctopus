<Window x:Class="RdpOctopus.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RdpOctopus"
        xmlns:controls="clr-namespace:RdpOctopus.Views"
        mc:Ignorable="d"
        Title="RdpOctopus" 
        Height="500" 
        Width="800"
        MinHeight="400"
        MinWidth="600"
        RenderOptions.EdgeMode="Aliased"
        WindowStartupLocation="CenterScreen">
    <Grid Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="1" Margin="0" SelectionChanged="TabControl_SelectionChanged">
            <TabItem Header="Ввод">
                <controls:InputControl Margin="0"/>
            </TabItem>
            <TabItem Header="Передача файла в RDP">
                <controls:RdpFileSendControl Margin="0"/>
            </TabItem>
            <TabItem Header="Получение файла в RDP">
                <controls:RdpGetFileControl Margin="0"/>
            </TabItem>
            <TabItem Header="Настройки ввода">
                <controls:SettingsControl Margin="0"/>
            </TabItem>
        </TabControl>
    </Grid>
</Window>