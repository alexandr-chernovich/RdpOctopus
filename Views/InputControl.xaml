<UserControl x:Class="RdpOctopus.Views.InputControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:RdpOctopus.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBox Grid.Row="0" 
                 Text="{Binding InputText}" 
                 Margin="0,0,0,12"
                 TextWrapping="Wrap"
                 AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto"/>

        <StackPanel Grid.Row="1" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right">
            <Button Content="Вставить из буфера"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Command="{Binding PasteFromClipboardCommand}"/>
            <Button Content="Запустить ввод"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding StartInputCommand}"/>
        </StackPanel>
    </Grid>
</UserControl>